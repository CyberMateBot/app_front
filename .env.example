# Dev: оставьте пустым — Vite proxy /v1 → http://127.0.0.1:8090 (без CORS).
# Prod / прямой доступ: https://your-api.up.railway.app
VITE_API_BASE_URL=

# true — только для локальной отладки вне Telegram (в prod не включать)
VITE_ENABLE_TELEGRAM_MOCK=false

VITE_APP_NAME=CyberMate
# Не используется для сборки реферальной ссылки (ссылка с API). Оставлено для прочих интеграций.
VITE_TELEGRAM_BOT_USERNAME=CyberMate_bot

# Кнопка Support → канал сообщества (не чат с ботом)
VITE_SUPPORT_TELEGRAM_INVITE_URL=https://t.me/+jXI2qDR9Y-xkZTI6

# Dev-only: принудительный план подписки для локального теста (free|basic|pro|max|ultra). ultra = Бизнес.
# Работает только при import.meta.env.DEV; в проде игнорируется. Оставьте пустым для обычного поведения.
VITE_FORCE_PLAN=
